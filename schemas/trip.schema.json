{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zendzipr.github.io/rv-expedition-logbook/schemas/trip.schema.json",
  "title": "Trip",
  "type": "object",
  "required": [
    "id",
    "name",
    "start_date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "travelers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "travel_days": {
      "type": "array",
      "items": {
        "$ref": "travel-day.schema.json"
      }
    },
    "provenance": {
      "$ref": "provenance.schema.json"
    }
  },
  "additionalProperties": true
}
