{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zendzipr.github.io/rv-expedition-logbook/schemas/provenance.schema.json",
  "title": "Provenance",
  "type": "object",
  "properties": {
    "source": {
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
