{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zendzipr.github.io/rv-expedition-logbook/schemas/campground.schema.json",
  "title": "Campground",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "string"
    },
    "site": {
      "type": "string"
    },
    "hookups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "connectivity": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "would_return": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "provenance": {
      "$ref": "provenance.schema.json"
    }
  },
  "additionalProperties": true
}
